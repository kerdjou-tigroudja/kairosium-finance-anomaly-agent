# =============================================================================
# AUTHENTIFICATION — Vertex AI via ADC
# Prérequis : gcloud auth application-default login
# =============================================================================

# Mettre à True pour utiliser Vertex AI (obligatoire en production)
GOOGLE_GENAI_USE_VERTEXAI=True

# GCP Project ID — GCP Console → page d'accueil → "Informations sur le projet"
GOOGLE_CLOUD_PROJECT=

# Région Vertex AI
GOOGLE_CLOUD_LOCATION=europe-west1

# =============================================================================
# CONFIGURATION AGENT
# =============================================================================

# ID du dataset BigQuery pour audit_reports, agent_events et test_runs
BQ_DATASET_ID=

# ID du modèle Gemini — override de config/agent_config.json si défini
MODEL_ID=gemini-2.5-flash

# =============================================================================
# SLACK — webhook optionnel pour trigger_alert (urllib stdlib, hors Cloud Monitoring)
# =============================================================================
# URL complète du Incoming Webhook (Slack → Apps → Incoming Webhooks).
# Format documenté par Slack : https + domaine slack + chemin /services/T…/B…/…
SLACK_WEBHOOK_URL=
